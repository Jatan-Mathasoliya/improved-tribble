# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Session
SESSION_SECRET=your-secret-key-here-change-in-production

# Google Cloud Storage (for resume/file uploads)
# Create a service account at https://console.cloud.google.com/iam-admin/serviceaccounts
# Grant "Storage Object Admin" role to the service account for your GCS bucket
GCS_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-bucket-name
GCS_SERVICE_ACCOUNT_KEY='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# Optional (preferred in local dev): absolute path to service-account JSON file.
# When set, this takes precedence over GCS_SERVICE_ACCOUNT_KEY.
# GCS_SERVICE_ACCOUNT_KEY_FILE=/absolute/path/to/gcs-service-account.json

# Cloudinary (DEPRECATED - use GCS instead)
# CLOUDINARY_CLOUD_NAME=your-cloud-name
# CLOUDINARY_API_KEY=your-api-key
# CLOUDINARY_API_SECRET=your-api-secret

# Groq (Optional - for AI-powered job analysis)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Email Configuration
# ===================
# VantaHire supports email notifications for:
# - User registration verification
# - Password reset
# - Application status updates
# - Hiring manager invitations
#
# IMPORTANT: Without proper email configuration, the system falls back to
# Ethereal (https://ethereal.email) - a FAKE email service for development.
# Ethereal emails are NOT delivered. Preview URLs are logged to console only.
#
# For PRODUCTION, you MUST configure a real email provider (Brevo recommended):
#
EMAIL_PROVIDER=brevo
SEND_FROM_EMAIL=no-reply@yourdomain.com
SEND_FROM_NAME=VantaHire
NOTIFICATION_EMAIL=alerts@yourdomain.com
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_USER=apikey
BREVO_SMTP_PASSWORD=your-brevo-smtp-key
#
# To get Brevo credentials:
# 1. Sign up at https://www.brevo.com
# 2. Go to SMTP & API > SMTP
# 3. Generate an SMTP key
# 4. Use "apikey" as BREVO_SMTP_USER
# 5. Use the generated key as BREVO_SMTP_PASSWORD
# 6. Verify your sending domain in Brevo settings

# ATS Automation (Optional)
EMAIL_AUTOMATION_ENABLED=true

# WhatsApp Notifications (Optional)
# Enable WhatsApp notifications alongside email
WHATSAPP_ENABLED=true
# Default country code for phone number parsing (ISO 3166-1 alpha-2)
WHATSAPP_DEFAULT_COUNTRY=IN
# Provider: 'test' (default, logs to console) or 'meta' (production)
WHATSAPP_PROVIDER=test

# Meta WhatsApp Business API (only needed when WHATSAPP_PROVIDER=meta)
# Get credentials from Meta Business Manager: https://business.facebook.com/
# WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-custom-verify-token
# WHATSAPP_API_VERSION=v18.0
# WHATSAPP_PROVIDER="aisensy" #set as "meta" or "aisensy" for production or "test" for local testing
# Meta WhatsApp Business API (only needed when WHATSAPP_PROVIDER=meta)
# Get credentials from Meta Business Manager: https://business.facebook.com/
# WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
# WHATSAPP_APP_SECRET=your-app-secret
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-custom-verify-token
# WHATSAPP_API_VERSION=v18.0

# AiSensy WhatsApp API (only needed when WHATSAPP_PROVIDER=aisensy)
# Get API key from AiSensy dashboard: https://app.aisensy.com/
# AISENSY_API_KEY=your-aisensy-api-key


# SEO Feature Flags (Phase 2)
# Dynamic jobs sitemap generation (default: enabled)
SEO_ENABLE_SITEMAP_JOBS=true

# Forms Feature Configuration (Optional)
# How many days until form invitations expire
FORM_INVITE_EXPIRY_DAYS=14
# Rate limit for public form endpoints (requests per minute per IP)
FORM_PUBLIC_RATE_LIMIT=10
# Rate limit for sending form invitations (per day per recruiter)
FORM_INVITE_DAILY_LIMIT=50
# Base URL for generating form links in emails (IMPORTANT: use HTTPS in production)
BASE_URL=https://yourdomain.com

# Admin User (Optional - auto-generates secure password if not set)
ADMIN_PASSWORD=your-secure-admin-password

# Google Analytics 4
# Get your Measurement ID from https://analytics.google.com
# Admin → Data Streams → Web → Measurement ID (starts with G-)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Server Configuration
NODE_ENV=production
PORT=5000

# ===================
# Organization & Subscription System
# ===================

# Cashfree Payment Gateway
# Get credentials from https://merchant.cashfree.com
CASHFREE_APP_ID=your-cashfree-app-id
CASHFREE_SECRET_KEY=your-cashfree-secret-key
CASHFREE_WEBHOOK_SECRET=your-cashfree-webhook-secret
# Use SANDBOX for testing, PRODUCTION for live
CASHFREE_ENV=SANDBOX

# GST Configuration (India)
# GST rate as percentage (18% in India)
GST_RATE=18
# Your company's GSTIN for invoices
COMPANY_GSTIN=your-company-gstin
# Legal name to appear on invoices
COMPANY_LEGAL_NAME=Your Company LLP

# Free Plan AI Credits (Optional)
# Monthly credits for free plan
FREE_AI_CREDITS_PER_MONTH=5
# Rollover months for free plan credits (cap = credits * months)
FREE_AI_CREDITS_ROLLOVER_MONTHS=3
# Optional explicit cap override (leave empty to auto-calc)
# FREE_AI_CREDITS_CAP=15

# Instance Type Configuration
# multi_tenant: Standard SaaS deployment (default)
# single_tenant: Business plan deployments
INSTANCE_TYPE=multi_tenant
# Set to true to disable super_admin features (for Business plan)
DISABLE_SUPER_ADMIN=false

# Signal & ActiveKG RS256 JWT Auth
# SIGNAL_BASE_URL=https://signal.example.com
VANTAHIRE_JWT_PRIVATE_KEY=  # PEM-encoded RS256 private key (or base64-encoded PEM) for signing outbound JWTs to Signal & ActiveKG
VANTAHIRE_JWT_ACTIVE_KID=v1  # Key ID included in JWT protected header
# SIGNAL_JWT_PUBLIC_KEY=  # PEM-encoded RS256 public key (or base64-encoded PEM) for verifying Signal callback JWTs

# ===================
# ActiveKG Graph Sync (Resume → Knowledge Graph)
# ===================
ACTIVEKG_SYNC_ENABLED=false
ACTIVEKG_TENANT_STRATEGY=default
ACTIVEKG_BASE_URL=http://localhost:8000
ACTIVEKG_TIMEOUT_MS=10000
ACTIVEKG_SYNC_BATCH_SIZE=20
ACTIVEKG_SYNC_INTERVAL_MS=5000
ACTIVEKG_SYNC_MAX_ATTEMPTS=8
ACTIVEKG_SYNC_CONCURRENCY=2
ACTIVEKG_CHUNK_MAX_CHARS=8000
ACTIVEKG_CHUNK_OVERLAP_CHARS=500
ACTIVEKG_SYNC_PROCESSING_LEASE_MS=300000
# ACTIVEKG_TENANT_PREFIX=org                     # Prefix for org-scoped tenant IDs (default: 'org')
#
# ActiveKG Search Tuning
# ACTIVEKG_SEARCH_MODE=hybrid                    # 'hybrid' | 'vector' | 'keyword' (default: 'hybrid')
# ACTIVEKG_SEARCH_TOP_K=20                       # Max results per search (1-100, default: 20)
# ACTIVEKG_SEARCH_USE_RERANKER=true              # Enable reranker pass (default: true)
# ACTIVEKG_SEARCH_SIGNED_URL_MINUTES=15          # Signed URL expiry for resume downloads (1-1440 min, default: 15)
